# second-opinion-mcp — Provider API Keys
# Set at least ONE key. The server auto-detects which provider to use.
# Detection priority: gemini > openai > groq > deepseek

# Google Gemini (free tier: 15 RPM, 1M tokens/day)
# Get your key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here

# OpenAI (pay-as-you-go)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-key-here

# Groq (free tier: 30 RPM, 14.4K tokens/min for llama-3.3-70b)
# Get your key: https://console.groq.com/keys
# GROQ_API_KEY=your-key-here

# DeepSeek (pay-as-you-go, very cheap)
# Get your key: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your-key-here

# --- Optional overrides ---

# Force a specific provider (ignores auto-detection)
# SECOND_OPINION_PROVIDER=gemini

# Force a specific model (overrides provider default)
# SECOND_OPINION_MODEL=gemini-2.5-pro
